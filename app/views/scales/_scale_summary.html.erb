<div id="scale">
  <div data-controller="piano-scale-search">
    <div class="bg-slate-200 text-slate-500 w-full flex">
      <%= form_with(url: search_scales_path) do |form| %>
        <div class="flex">
          <h2 class="p-2 pl-4">SCALE TYPE:</h2>
          <%= form.select :scale_type,
            options_for_select(scale_types, scale_type),
            {},
            { class: 'focus:outline-none focus:ring-transparent bg-slate-200 border-none' } %>
          <h2 class="ml-4 p-2 pl-4">SEARCH BY:</h2>
          <%= select_tag :note_input_type,
            options_for_select([['Piano', 'piano']], 'piano'),
            { class: 'focus:outline-none focus:ring-transparent bg-slate-200 border-none' } %>
        </div>
        <%= form.text_field :query, hidden: true %>
      <% end %>
    </div>

    <div class="flex flex-wrap items-center justify-start mt-4 p-2 pb-6">
      <%= render "scales/piano_component",
        root_note: root_note,
        note_names: note_names  %>
    </div>

    <% if scale.present? %>
      <div class="mt-4 pb-6 flex items-end">
        <div>
          <div class="text-lg font-sans font-thin">
            name
          </div>
          <div class="bg-slate-200 text-lg font-sans font-thin pl-4">
            <span class="text-6xl font-sans font-thin">
              <span class="mr-4"><%= scale.tone.name %></span><%= scale.name %>
            </span>
          </div>
        </div>
        <div>
          <div class="text-lg font-sans font-thin">
            name
          </div>
          <div class="bg-slate-200 text-lg font-sans font-thin pl-4">
            <% scale.notes.each do |n| %>
              <span class="text-4xl mr-4">
                <%= n.pretty_name %>
              </span>
            <% end %>
          </div>
        </div>
      </div>
    <% else %>
      <div class="bg-slate-200 text-slate-500 w-1/2 p-4">
        <h2 class="pb-2">HOW TO:</h2>
        <p>Select a Scale Type from the drop down and click on/tap a note to show the scale details and highlight the scale's notes above.</p>
      </div>
    <% end %>

    <% if error.present? %>
      <span class="text-2xl font-sans">
        <%= error %>
      </span>
    <% end %>
  </div>
</div>
