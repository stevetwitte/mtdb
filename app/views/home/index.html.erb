<div class="m-auto text-left">
  <%= render 'components/section_heading', text: @breadcrumbs %>
  <div class="flex flex-wrap items-center justify-start mt-4 p-2 pl-4 pb-6">
    <%= render "components/big_menu_button",
      link_path: theory_index_path,
      image_path: 'glyphicons-basic-422-book-library.svg',
      bg_class: 'bg-gradient-to-br from-pink-400 to-purple-400',
      text: t('theory') %>

    <%= render "components/big_menu_button",
      link_path: '',
      image_path: 'glyphicons-basic-73-bookmark.svg',
      bg_class: 'bg-gradient-to-br from-yellow-400 to-pink-400',
      text: t('library') %>

    <%= render "components/big_menu_button",
      link_path: tools_index_path,
      image_path: 'glyphicons-basic-5-settings.svg',
      bg_class: 'bg-gradient-to-br from-cyan-400 to-green-400',
      text: t('tools') %>

    <%= render "components/big_menu_button",
      link_path: '',
      image_path: 'glyphicons-basic-137-cogwheel.svg',
      bg_class: 'bg-gradient-to-br from-purple-400 to-cyan-400',
      text: t('settings') %>
  </div>
</div>

<div class="m-auto text-left">
  <%= render 'components/section_heading', text: t('recently saved') %>
  <div class="relative mt-4 p-2 pl-4 pb-6">
    <% unless user_signed_in? %>
      <div class="absolute flex justify-center items-center top-0 left-0 right-0 bottom-0 z-20">
        <%= link_to t('new user pull quote'),
          new_user_registration_path,
          class: 'text-xl opacity-100 p-4 px-6 text-2xl uppercase border-violet-400 border-2 bg-slate-900 text-gray-200' %>
      </div>
    <% end %>
    <% unless user_signed_in? %>
      <div class="absolute flex justify-center items-center top-0 left-0 right-0 bottom-0 z-10 bg-gradient-to-br from-pink-400 to-purple-400 opacity-10"></div>
    <% end %>
    <div class="shadow-sm overflow-hidden">
      <table class="table-auto">
        <thead>
          <tr>
            <th class="text-lg pr-12 pl-0 pt-0 pb-3 text-left text-violet-400 uppercase">Key</th>
            <th class="text-lg pr-12 pl-0 pt-0 pb-3 text-left text-violet-400 uppercase">Name</th>
            <th class="text-lg pl-0 pt-0 pr-12 pb-3 text-left text-violet-400 uppercase">Type</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="text-gray-200 text-lg pb-2 pr-12">A</td>
            <td class="text-gray-200 text-lg pb-2 pr-12">Melodic Minor</td>
            <td class="text-gray-200 text-lg pb-2 pr-12">Scale</td>
          </tr>
          <tr>
            <td class="text-gray-200 text-lg pb-2 pr-12">C</td>
            <td class="text-gray-200 text-lg pb-2 pr-12">Harmonic Minor</td>
            <td class="text-gray-200 text-lg pb-2 pr-12">Scale</td>
          </tr>
          <tr>
            <td class="text-gray-200 text-lg pb-2 pr-12">D</td>
            <td class="text-gray-200 text-lg pb-2 pr-12">Minor</td>
            <td class="text-gray-200 text-lg pb-2 pr-12">Chord</td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
